{
  // TypeScript configuration for the Finance Stack Next.js application.
  // Generated by create-next-app (Next.js 16) — customizations should be
  // made here rather than overridden elsewhere.
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true, // Next.js handles compilation; TypeScript is used only for type-checking
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler", // Required for Next.js App Router
    "resolveJsonModule": true,
    "isolatedModules": true, // Required — ensures compatibility with Turbopack
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next" // Enables Next.js-specific type checking (route types, metadata, etc.)
      }
    ],
    "paths": {
      "@/*": ["./*"] // Import alias — use @/lib/db, @/components/ui, etc.
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts", // Auto-generated route and layout types
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
