# Version control
.git

# Root-level dependencies
node_modules/

# Python artifacts
__pycache__/
*.pyc
*.pyo

# Importer service — user-specific files
imports/
importer/parsers/

# IDE
.vscode/

# TypeScript build artifacts
app/tsconfig.tsbuildinfo
app/next-env.d.ts

# CI / GitHub
.github

# IDE and tooling
.vs
.claude

# Credentials
.env
secrets/

# Documentation
*.md
# …but CHANGELOG.md must reach the image: this file is the `changelog` build
# context (docker-compose.yml additional_contexts) that the runner stage copies
# in for the /settings/about "What's New" page. Un-ignore it.
!CHANGELOG.md

# Next.js development artifacts
app/node_modules
app/.next
app/.env.local

# Test files and output
app/tests
app/coverage
app/.vitest
app/vitest.config.ts
