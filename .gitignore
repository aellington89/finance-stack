# IDE and tooling
/.vs
/.claude

# Root-level dependencies
node_modules/

# Python artifacts (importer service)
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Credentials — never commit
.env

# Next.js application (app/ directory)
app/node_modules
app/.next
app/.env.local
app/out
app/.claude

# Importer — parsers are user-specific, drop folder contains user documents
imports/
importer/parsers/

# Test output
app/coverage
app/.vitest